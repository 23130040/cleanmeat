<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<%@ page contentType="text/html;charset=UTF-8" language="java" %>

<div class="return-policy">
    <div class="container">
        <div class="policy-header">
            <h1 class="policy-title big-title">
                HƯỚNG DẪN ĐẶT HÀNG
            </h1>
            <p class="policy-description">
                Mua sắm dễ dàng chỉ với vài bước đơn giản, nhanh chóng và tiện lợi.
            </p>
        </div>

        <div class="policy-section policy-conditions">
            <h3 class="section-title normal-title">
                Các bước đặt hàng
            </h3>
            <ul class="policy-list">
                <li>Truy cập vào trang <b>Sản phẩm</b>.</li>
                <li>Chọn sản phẩm bạn muốn mua.</li>
                <li>Nhấn <b>Thêm vào giỏ hàng</b>.</li>
                <li>Vào giỏ hàng để kiểm tra sản phẩm.</li>
                <li>Nhấn <b>Thanh toán</b> và điền thông tin.</li>
                <li>Xác nhận đơn hàng.</li>
            </ul>
        </div>

        <div class="policy-section policy-time">
            <h3 class="section-title normal-title">
                Lưu ý khi đặt hàng
            </h3>
            <div class="policy-box">
                <h4 class="sub-normal-title">
                    Trước khi đặt hàng
                </h4>
                <p>
                    Vui lòng kiểm tra kỹ thông tin nhận hàng như địa chỉ và số điện thoại.
                    Đảm bảo sản phẩm, số lượng và giá tiền chính xác trước khi thanh toán.
                </p>
            </div>
        </div>

        <div class="policy-section policy-process">
            <h3 class="section-title normal-title">
                Quy trình xử lý đơn hàng
            </h3>
            <ol class="policy-process-list">
                <li>
                    <strong>Tiếp nhận đơn hàng</strong><br>
                    Hệ thống ghi nhận đơn hàng của bạn.
                </li>
                <li>
                    <strong>Xác nhận thông tin</strong><br>
                    Nhân viên sẽ liên hệ để xác nhận đơn hàng.
                </li>

                <li>
                    <strong>Đóng gói & giao hàng</strong><br>
                    Đơn hàng được chuẩn bị và gửi đi.
                </li>
                <li>
                    <strong>Nhận hàng & thanh toán</strong><br>
                    Khách hàng nhận hàng và thanh toán (nếu COD).
                </li>
            </ol>
        </div>

        <div class="policy-support">
            <h3 class="support-title normal-title">
                Cần hỗ trợ thêm?
            </h3>
            <p>
                Đội ngũ chăm sóc khách hàng luôn sẵn sàng hỗ trợ bạn.
            </p>
            <div class="support-contact">
                <span><i class="fa-solid fa-phone"></i> 1900 xxxx</span>
                <span><i class="fa-regular fa-envelope"></i> support@cleanmeat.vn</span>
            </div>
        </div>

    </div>
</div>